<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Student Dashboard | MathWorld</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Nunito', sans-serif; background: #FFFBF0; }
    .brand { font-family: 'Fredoka One', cursive; color: #7C5CFC; }
    .module-card { transition: transform 0.3s; border: none; border-radius: 20px; }
    .module-card:hover { transform: translateY(-10px); }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container py-5">
    <h1 class="brand mb-4">Welcome back, Little Mathematician!</h1>
    <div class="row g-4">
      <div class="col-md-4">
        <div class="card module-card shadow p-4 text-center bg-white">
          <h3 class="brand text-warning">Counting Fun</h3>
          <p>Master numbers 1-100 with colorful games!</p>
          <button class="btn btn-warning rounded-pill">Start Learning</button>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card module-card shadow p-4 text-center bg-white">
          <h3 class="brand text-primary">Addition Land</h3>
          <p>Join the addition party and add like a pro!</p>
          <button class="btn btn-primary rounded-pill">Join Now</button>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card module-card shadow p-4 text-center bg-white">
          <h3 class="brand text-success">Shape Explorer</h3>
          <p>Discover squares, circles, and triangles!</p>
          <button class="btn btn-success rounded-pill">Explore</button>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
</body>
</html>
