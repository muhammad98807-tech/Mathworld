<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FAQ | MathWorld Primary</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Nunito', sans-serif; background: #FFFBF0; color: #1E2A4A; }
    h1 { font-family: 'Fredoka One', cursive; color: #7C5CFC; }
    .faq-container { max-width: 800px; margin: 50px auto; padding: 20px; }
    .accordion-button:not(.collapsed) { background-color: #7C5CFC; color: white; }
  </style>
</head>
<body>
  <div class="container faq-container">
    <h1 class="text-center mb-5">Frequently Asked Questions</h1>
    <div class="accordion" id="faqAccordion">
      <div class="accordion-item">
        <h2 class="accordion-header">
          <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
            What is MathWorld Primary?
          </button>
        </h2>
        <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
          <div class="accordion-body">
            MathWorld Primary is an interactive learning platform designed for students in grades 1 to 5 to master mathematics through fun and engagement.
          </div>
        </div>
      </div>
    </div>
    <div class="text-center mt-4">
        <a href="/" class="btn btn-primary">Back to Home</a>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
