   INIT
══════════════════════════════════════════ */
document.addEventListener('DOMContentLoaded',()=>{
  showPage('home');
  applyRoleUI();
  /* ESC closes YT modal */
  document.addEventListener('keydown',e=>{ if(e.key==='Escape') closeYtModal({}); });
});


// ========== SCROLL FUNCTIONS ==========
function scrollToTop() {
  window.scrollTo({
    top: 0,
    behavior: 'smooth'
  });
}

function scrollToBottom() {
  window.scrollTo({
    top: document.body.scrollHeight,
    behavior: 'smooth'
  });
}

// Show/hide scroll buttons based on scroll position
function checkScrollPosition() {
  const scrollUpBtn = document.getElementById('scrollUpBtn');
  const scrollDownBtn = document.getElementById('scrollDownBtn');
  
  if (!scrollUpBtn || !scrollDownBtn) return;
  
  const scrollPosition = window.scrollY;
  const pageHeight = document.body.scrollHeight;
  const windowHeight = window.innerHeight;
  
  // Show scroll up button when scrolled down more than 300px
  if (scrollPosition > 300) {
    scrollUpBtn.classList.add('show');
  } else {
    scrollUpBtn.classList.remove('show');
  }
  
  // Show scroll down button when not at bottom
  if (scrollPosition + windowHeight < pageHeight - 100) {
    scrollDownBtn.classList.add('show');
  } else {
    scrollDownBtn.classList.remove('show');
  }
}

// Listen to scroll event
window.addEventListener('scroll', checkScrollPosition);
window.addEventListener('resize', checkScrollPosition);

// Call on page load
document.addEventListener('DOMContentLoaded', function() {
  checkScrollPosition();
});
</script>








