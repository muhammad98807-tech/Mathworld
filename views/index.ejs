<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
/* ══════════════════════════════════════════
   STATE
══════════════════════════════════════════ */
let currentRole = 'student';
let currentPage = 'home';
let activeGrade  = null;
let activeSubTabs = {1:'pdfs',2:'pdfs',3:'pdfs',4:'pdfs',5:'pdfs'};

/* grade colours for active tab */
const gradeColors = {1:'var(--g1)',2:'var(--g2)',3:'var(--g3)',4:'var(--g4)',5:'var(--g5)'};
const gradeSubTabColors = {
  1:'#FF6B6B',2:'#FB923C',3:'#D4AC00',4:'#22C55E',5:'#7C5CFC'
};

/* ══════════════════════════════════════════
   PAGE ROUTER
══════════════════════════════════════════ */
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  document.querySelectorAll('.nav-link-btn').forEach(b => {
    b.classList.remove('active');
    if (b.textContent.toLowerCase().includes(id === 'grades-hub' ? 'grades hub' : id === 'grades' ? 'results' : id === 'quiz' ? 'quiz' : id)) b.classList.add('active');
  });
  currentPage = id;
  window.scrollTo({top:0,behavior:'smooth'});
}

/* ══════════════════════════════════════════
   OPEN GRADE FROM HOME CARD
══════════════════════════════════════════ */
function openGrade(n) {
  showPage('grades-hub');
  setTimeout(() => selectGrade(n), 100);
}

/* ══════════════════════════════════════════
   GRADE SELECTOR
══════════════════════════════════════════ */
function selectGrade(n) {
  activeGrade = n;

  /* update tabs */
  for (let i=1;i<=5;i++) {
    const tab = document.getElementById('gtab-'+i);
    tab.classList.remove('active');
    tab.style.background = '#fff';
  }
  const t = document.getElementById('gtab-'+n);
  t.classList.add('active');
  t.style.background = gradeColors[n];
  t.style.borderColor = gradeColors[n];
  t.style.color = '#fff';

  /* show panel */
  document.querySelectorAll('.grade-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('panel-'+n).classList.add('active');
  document.getElementById('no-grade-msg').style.display='none';

  /* render lazy timetable & notepad if not done */
  renderTimetable(n);
  renderNotepad(n);

  /* show correct sub-tab */
  showSubTab(n, activeSubTabs[n]);
}

/* ══════════════════════════════════════════
   SUB TABS
══════════════════════════════════════════ */
function showSubTab(grade, tab) {
  activeSubTabs[grade] = tab;
  const tabs = ['pdfs','videos','timetable','notepad'];
  tabs.forEach(t => {
    const el = document.getElementById('s'+grade+'-'+t);
    if (el) el.classList.toggle('d-none', t !== tab);
    const btn = document.getElementById('st'+grade+'-'+t);
    if (btn) {
      btn.classList.toggle('active', t === tab);
      if (t === tab) {
        btn.style.background = gradeSubTabColors[grade];
        btn.style.color = '#fff';
      } else {
        btn.style.background = '';
        btn.style.color = '';
      }
    }
  });
}

/* ══════════════════════════════════════════
   TIMETABLE RENDERER
══════════════════════════════════════════ */
const timetableData = {
  1: { title:'Grade 1 Weekly Lecture Schedule', color:'#FF6B6B',
    sessions:[
      {day:'Monday',time:'9:00–9:45',topic:'Addition Basics',type:'live'},
      {day:'Wednesday',time:'9:00–9:45',topic:'Subtraction Practice',type:'live'},
      {day:'Friday',time:'10:00–10:30',topic:'Number Lines Review',type:'revision'},
    ]},
  2: { title:'Grade 2 Weekly Lecture Schedule', color:'#FB923C',
    sessions:[
      {day:'Monday',time:'10:00–10:45',topic:'Place Value',type:'live'},
      {day:'Tuesday',time:'9:30–10:00',topic:'2D Shapes Intro',type:'live'},
      {day:'Thursday',time:'9:00–9:30',topic:'Tens & Hundreds',type:'revision'},
    ]},
  3: { title:'Grade 3 Weekly Lecture Schedule', color:'#D4AC00',
    sessions:[
      {day:'Monday',time:'11:00–11:45',topic:'Times Tables 1–5',type:'live'},
      {day:'Wednesday',time:'11:00–11:45',topic:'Times Tables 6–10',type:'live'},
      {day:'Friday',time:'11:00–11:30',topic:'Division Practice',type:'revision'},
    ]},
  4: { title:'Grade 4 Weekly Lecture Schedule', color:'#22C55E',
    sessions:[
      {day:'Tuesday',time:'10:00–10:45',topic:'Angles & Triangles',type:'live'},
      {day:'Thursday',time:'10:00–10:45',topic:'Geometry Review',type:'live'},
      {day:'Friday',time:'9:30–10:00',topic:'Word Problems',type:'revision'},
    ]},
  5: { title:'Grade 5 Weekly Lecture Schedule', color:'#7C5CFC',
    sessions:[
      {day:'Monday',time:'12:00–12:45',topic:'Fractions',type:'live'},
      {day:'Wednesday',time:'12:00–12:45',topic:'Decimals',type:'live'},
      {day:'Friday',time:'12:00–12:30',topic:'Algebra Intro',type:'revision'},
    ]},
};

const renderedTT = {};
function renderTimetable(n) {
  if (renderedTT[n]) return;
  renderedTT[n] = true;
  const data = timetableData[n];
  const days = ['Monday','Tuesday','Wednesday','Thursday','Friday'];
  const col = data.color;

  let html = `<div style="background:#fff;border-radius:16px;padding:1.5rem;box-shadow:0 3px 14px rgba(0,0,0,.07)">
    <h5 style="font-family:'Fredoka One',cursive;color:var(--navy);margin-bottom:.3rem">${data.title}</h5>
    <p class="text-muted small mb-3">Your live lecture and revision sessions for the week.</p>
    <div class="timetable-wrap"><table class="timetable">
      <thead><tr><th style="width:90px">Time</th>${days.map(d=>`<th>${d}</th>`).join('')}</tr></thead>
      <tbody>`;

  /* build time slots */
  const allTimes = [...new Set(data.sessions.map(s=>s.time))].sort();
  allTimes.forEach(time => {
    html += `<tr><td class="row-label">${time}</td>`;
    days.forEach(day => {
      const sess = data.sessions.find(s=>s.day===day&&s.time===time);
      if (sess) {
        const bg = sess.type==='live' ? col : '#E2E8F0';
        const tc = sess.type==='live' ? '#fff' : '#475569';
        const icon = sess.type==='live' ? '📡' : '📖';
        html += `<td class="slot-active" style="background:${bg};color:${tc}">${icon} ${sess.topic}<br><small style="opacity:.8;font-size:.72rem">${sess.type==='live'?'Live Lecture':'Revision'}</small></td>`;
      } else {
        html += `<td class="slot-break">—</td>`;
      }
    });
    html += `</tr>`;
  });

  html += `</tbody></table></div>
    <div class="timetable-legend mt-3">
      <div class="legend-dot"><span style="background:${col}"></span> Live Lecture</div>
      <div class="legend-dot"><span style="background:#E2E8F0"></span> Revision Session</div>
      <div class="legend-dot"><span style="background:#F8FAFC;border:1px solid #E2E8F0"></span> Free Period</div>
    </div>
    <p class="text-muted small mt-2"><i class="bi bi-info-circle me-1"></i>All live lectures are held in the classroom. Attend on time!</p>
  </div>`;
  document.getElementById('tt-container-'+n).innerHTML = html;
}

/* ══════════════════════════════════════════
   NOTEPAD RENDERER
══════════════════════════════════════════ */
const renderedNP = {};
function renderNotepad(n) {
  if (renderedNP[n]) return;
  renderedNP[n] = true;
  const col = gradeSubTabColors[n];
  const savedKey = 'mathworld_note_g'+n;
  const saved = localStorage.getItem(savedKey) || '';
  document.getElementById('np-container-'+n).innerHTML = `
  <div class="notepad-wrap">
    <div class="notepad-header" style="border-top:4px solid ${col}">
      <div><strong style="font-family:'Fredoka One',cursive;color:var(--navy);font-size:1.1rem">📝 My Notes — Grade ${n}</strong><br><small class="text-muted">Write notes while watching lectures. Auto-saved in your browser!</small></div>
      <span class="note-saved" id="note-saved-${n}">✅ Saved!</span>
    </div>
    <textarea class="notepad-textarea" id="notepad-${n}" placeholder="Start writing your notes here… e.g. 'Addition means combining two groups together. Example: 3 + 4 = 7'"
      oninput="autoSaveNote(${n})">${saved}</textarea>
    <div class="notepad-toolbar">
      <button class="note-btn" onclick="formatNote(${n},'bold')"><i class="bi bi-type-bold"></i> Bold</button>
      <button class="note-btn" onclick="formatNote(${n},'bullet')">• List</button>
      <button class="note-btn" onclick="formatNote(${n},'date')">📅 Date</button>
      <button class="note-btn" onclick="downloadNote(${n})">⬇️ Download</button>
      <button class="note-btn" onclick="printNote(${n})">🖨️ Print</button>
      <button class="note-btn danger" onclick="clearNote(${n})">🗑️ Clear</button>
      <span class="ms-auto text-muted" style="font-size:.75rem" id="note-count-${n}">0 chars</span>
    </div>
  </div>`;
  updateNoteCount(n);
}

function autoSaveNote(n) {
  const val = document.getElementById('notepad-'+n).value;
  localStorage.setItem('mathworld_note_g'+n, val);
  const s = document.getElementById('note-saved-'+n);
  s.classList.add('show');
  clearTimeout(s._t);
  s._t = setTimeout(()=>s.classList.remove('show'),2000);
  updateNoteCount(n);
}

function updateNoteCount(n) {
  const el = document.getElementById('notepad-'+n);
  const c = document.getElementById('note-count-'+n);
  if (el && c) c.textContent = el.value.length + ' chars';
}

function formatNote(n, type) {
  const ta = document.getElementById('notepad-'+n);
  const start = ta.selectionStart, end = ta.selectionEnd;
  let insert = '';
  if (type==='bold') insert = '**' + (ta.value.slice(start,end)||'text') + '**';
  if (type==='bullet') insert = '\n• ';
  if (type==='date') insert = '\n📅 ' + new Date().toLocaleDateString('en-GB',{weekday:'long',year:'numeric',month:'long',day:'numeric'}) + '\n';
  ta.value = ta.value.slice(0,start) + insert + ta.value.slice(end);
  ta.focus();
  autoSaveNote(n);
}

function downloadNote(n) {
  const text = document.getElementById('notepad-'+n).value;
  const blob = new Blob([text],{type:'text/plain'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `Grade${n}_MathNotes.txt`;
  a.click();
  showToast('📥 Notes downloaded!','success');
}

function printNote(n) {
  const text = document.getElementById('notepad-'+n).value;
  const win = window.open('','_blank');
  win.document.write(`<pre style="font-family:serif;font-size:14px;line-height:1.8;padding:20px">${text}</pre>`);
  win.print(); win.close();
}

function clearNote(n) {
  if (!confirm('Clear all notes for Grade '+n+'?')) return;
  document.getElementById('notepad-'+n).value = '';
  localStorage.removeItem('mathworld_note_g'+n);
  updateNoteCount(n);
  showToast('🗑️ Notes cleared','info');
}

/* ══════════════════════════════════════════
   YOUTUBE MODAL
══════════════════════════════════════════ */
function openYt(id, title) {
  document.getElementById('ytFrame').src = 'https://www.youtube.com/embed/'+id+'?autoplay=1';
  document.getElementById('ytModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeYtModal(e) {
  if (e && e.target !== document.getElementById('ytModal') && !e.target.closest('.yt-modal-close')) return;
  document.getElementById('ytFrame').src = '';
  document.getElementById('ytModal').classList.remove('open');
  document.body.style.overflow = '';
}

/* ══════════════════════════════════════════
   QUIZ SYSTEM
══════════════════════════════════════════ */
const builtInQuizzes = {
  1: { title:'Grade 1: Addition & Subtraction Quiz', questions:[
    {q:'What is 3 + 4?', opts:['5','6','7','8'], ans:2},
    {q:'What is 9 - 3?', opts:['4','5','6','7'], ans:2},
    {q:'How many is 2 + 2 + 2?', opts:['4','5','6','7'], ans:2},
    {q:'What is 10 - 4?', opts:['4','5','6','7'], ans:2},
    {q:'Sam has 5 apples and gets 3 more. How many?', opts:['6','7','8','9'], ans:2},
  ]},
  2: { title:'Grade 2: Place Value Quiz', questions:[
    {q:'What is the tens digit in 47?', opts:['7','4','0','1'], ans:1},
    {q:'Which number has 5 tens and 2 ones?', opts:['25','52','205','520'], ans:1},
    {q:'How many sides does a square have?', opts:['3','4','5','6'], ans:1},
    {q:'What is 60 + 8?', opts:['86','68','78','80'], ans:1},
    {q:'A triangle has ___ sides.', opts:['2','3','4','5'], ans:1},
  ]},
  3: { title:'Grade 3: Multiplication & Division Quiz', questions:[
    {q:'What is 6 × 7?', opts:['36','40','42','48'], ans:2},
    {q:'What is 48 ÷ 6?', opts:['6','7','8','9'], ans:2},
    {q:'What is 9 × 9?', opts:['72','81','90','63'], ans:1},
    {q:'24 ÷ 4 = ?', opts:['4','5','6','7'], ans:2},
    {q:'Which is 5 × 8?', opts:['35','40','45','50'], ans:1},
  ]},
  4: { title:'Grade 4: Geometry Quiz', questions:[
    {q:'How many degrees in a right angle?', opts:['45','60','90','180'], ans:2},
    {q:'A shape with 6 sides is called a?', opts:['Pentagon','Hexagon','Heptagon','Octagon'], ans:1},
    {q:'What is the perimeter of a square with side 5cm?', opts:['10cm','15cm','20cm','25cm'], ans:2},
    {q:'An equilateral triangle has ___ equal sides.', opts:['1','2','3','0'], ans:2},
    {q:'Parallel lines will ___?', opts:['cross eventually','never meet','always meet','form a circle'], ans:1},
  ]},
  5: { title:'Grade 5: Fractions & Decimals Quiz', questions:[
    {q:'What is 1/2 + 1/4?', opts:['1/6','2/6','3/4','2/8'], ans:2},
    {q:'0.5 is the same as?', opts:['1/4','1/3','1/2','3/4'], ans:2},
    {q:'What is 3/4 of 20?', opts:['10','12','15','18'], ans:2},
    {q:'Which decimal equals 3/10?', opts:['0.03','0.3','3.0','30'], ans:1},
    {q:'If x + 5 = 12, what is x?', opts:['5','6','7','8'], ans:2},
  ]},
};

let customQuizzes = JSON.parse(localStorage.getItem('mathworld_quizzes') || '{}');
let currentQuiz = null;
let currentQIdx = 0;
let quizScore = 0;
let answered = false;

function loadQuizForGrade(grade) {
  if (!grade) return;
  const g = parseInt(grade);
  const quiz = (customQuizzes[g] && customQuizzes[g].length > 0) ? customQuizzes[g][0] : builtInQuizzes[g];
  currentQuiz = quiz;
  currentQIdx = 0; quizScore = 0;
  document.getElementById('quiz-no-select').classList.add('d-none');
  document.getElementById('quiz-result-wrap').classList.add('d-none');
  document.getElementById('quiz-play-wrap').classList.remove('d-none');
  document.getElementById('quiz-play-title').textContent = quiz.title;
  renderQuestion();
}

function renderQuestion() {
  const q = currentQuiz.questions[currentQIdx];
  const total = currentQuiz.questions.length;
  answered = false;
  document.getElementById('quiz-prog-fill').style.width = ((currentQIdx/total)*100)+'%';
  document.getElementById('quiz-prog-label').textContent = `Question ${currentQIdx+1} of ${total}`;
  document.getElementById('quiz-q-text').textContent = q.q;
  document.getElementById('quiz-feedback').classList.add('d-none');
  document.getElementById('quiz-next-btn').classList.add('d-none');
  const opts = document.getElementById('quiz-options');
  opts.innerHTML = '';
  q.opts.forEach((opt,i) => {
    const btn = document.createElement('button');
    btn.className = 'quiz-option-btn';
    btn.textContent = opt;
    btn.onclick = () => selectAnswer(i, q.ans, btn);
    opts.appendChild(btn);
  });
}

function selectAnswer(idx, correct, btn) {
  if (answered) return;
  answered = true;
  const btns = document.querySelectorAll('.quiz-option-btn');
  btns.forEach(b => b.style.pointerEvents = 'none');
  const fb = document.getElementById('quiz-feedback');
  fb.classList.remove('d-none');
  if (idx === correct) {
    quizScore++;
    btn.classList.add('correct');
    btns[correct].classList.add('correct');
    fb.style.background = '#DCFCE7'; fb.style.color = '#15803D';
    fb.textContent = '✅ Correct! Well done!';
  } else {
    btn.classList.add('wrong');
    btns[correct].classList.add('correct');
    fb.style.background = '#FEE2E2'; fb.style.color = '#991B1B';
    fb.textContent = '❌ Not quite! The correct answer is: ' + currentQuiz.questions[currentQIdx].opts[correct];
  }
  const isLast = currentQIdx >= currentQuiz.questions.length - 1;
  const nextBtn = document.getElementById('quiz-next-btn');
  nextBtn.classList.remove('d-none');
  nextBtn.textContent = isLast ? 'See Results 🎉' : 'Next Question →';
}

function nextQuestion() {
  currentQIdx++;
  if (currentQIdx >= currentQuiz.questions.length) {
    showQuizResult();
  } else {
    renderQuestion();
  }
}

function showQuizResult() {
  document.getElementById('quiz-play-wrap').classList.add('d-none');
  document.getElementById('quiz-result-wrap').classList.remove('d-none');
  const total = currentQuiz.questions.length;
  const pct = Math.round((quizScore/total)*100);
  document.getElementById('quiz-score-display').textContent = quizScore+'/'+total;
  let msg, sub, bg, col;
  if (pct===100){msg='Perfect Score! 🌟';sub="You're a MathWorld star!";bg='#DCFCE7';col='#15803D';}
  else if(pct>=80){msg='Excellent! 🎉';sub="Great job! Keep it up!";bg='#DBEAFE';col='#1D4ED8';}
  else if(pct>=60){msg='Good Work! 👍';sub="Review the questions you missed.";bg='#FEF9C3';col='#854D0E';}
  else{msg='Keep Practising! 💪';sub="Review your lectures and try again!";bg='#FFE4E6';col='#BE123C';}
  const sd = document.getElementById('quiz-score-display');
  sd.style.background=bg; sd.style.color=col;
  document.getElementById('quiz-result-msg').textContent=msg;
  document.getElementById('quiz-result-sub').textContent=sub;
}

function retryQuiz() {
  currentQIdx=0; quizScore=0;
  document.getElementById('quiz-result-wrap').classList.add('d-none');
  document.getElementById('quiz-play-wrap').classList.remove('d-none');
  renderQuestion();
}

/* Teacher quiz builder */
let qbQuestions = [];

function showQuizBuilder() {
  document.getElementById('quiz-builder-section').classList.toggle('d-none');
}

function addQuestion() {
  const idx = qbQuestions.length;
  qbQuestions.push({q:'',opts:['','','',''],ans:0});
  const div = document.createElement('div');
  div.className = 'quiz-question-item';
  div.id = 'qitem-'+idx;
  div.innerHTML = `<div class="d-flex justify-content-between mb-2"><strong style="color:var(--violet)">Q${idx+1}</strong><button class="btn-danger-soft" style="font-size:.75rem;padding:.2rem .6rem" onclick="removeQuestion(${idx})">Remove</button></div>
    <input type="text" class="form-control mb-2" placeholder="Question text…" oninput="qbQuestions[${idx}].q=this.value">
    ${[0,1,2,3].map(o=>`
    <div class="quiz-option-row">
      <input type="radio" name="qb-ans-${idx}" value="${o}" onclick="qbQuestions[${idx}].ans=${o}">
      <input type="text" class="form-control form-control-sm" placeholder="Option ${o+1}…" style="flex:1" oninput="qbQuestions[${idx}].opts[${o}]=this.value">
      ${o===0?'<span class="quiz-correct-label">← mark correct</span>':''}
    </div>`).join('')}`;
  document.getElementById('qb-questions').appendChild(div);
  document.getElementById('qb-hint').textContent = 'Mark the correct answer with the radio button (●).';
}

function removeQuestion(idx) {
  const el = document.getElementById('qitem-'+idx);
  if (el) el.remove();
}

function saveQuiz() {
  const title = document.getElementById('qb-title').value.trim();
  const grade = parseInt(document.getElementById('qb-grade').value);
  if (!title || !grade) { showToast('⚠️ Please fill in quiz title and grade.','warning'); return; }
  const filled = qbQuestions.filter(q=>q.q && q.opts.every(o=>o));
  if (filled.length < 2) { showToast('⚠️ Add at least 2 complete questions.','warning'); return; }
  if (!customQuizzes[grade]) customQuizzes[grade] = [];
  customQuizzes[grade].unshift({title, questions:filled});
  localStorage.setItem('mathworld_quizzes', JSON.stringify(customQuizzes));
  qbQuestions = [];
  document.getElementById('qb-questions').innerHTML = '';
  document.getElementById('qb-title').value = '';
  showToast(`✅ Quiz "${title}" saved for Grade ${grade}!`,'success');
  renderSavedQuizzes();
  document.getElementById('quiz-builder-section').classList.add('d-none');
}

function renderSavedQuizzes() {
  const el = document.getElementById('saved-quizzes-list');
  const all = Object.entries(customQuizzes).flatMap(([g,qs])=>qs.map(q=>({...q,grade:g})));
  if (!all.length){el.innerHTML='<p class="text-muted small">No custom quizzes yet.</p>';return;}
  el.innerHTML = all.map((q,i)=>`<div class="d-flex align-items-center justify-content-between p-2 mb-1 rounded-2" style="background:#F8FAFC;border:1px solid #E2E8F0"><span><strong>${q.title}</strong> <span class="badge" style="background:#EDE9FE;color:var(--violet);border-radius:50px;font-size:.75rem">Grade ${q.grade}</span></span><button class="btn-danger-soft" style="font-size:.75rem" onclick="deleteCustomQuiz(${q.grade},${i})"><i class="bi bi-trash3"></i></button></div>`).join('');
}

function deleteCustomQuiz(grade, idx) {
  customQuizzes[grade].splice(idx,1);
  localStorage.setItem('mathworld_quizzes',JSON.stringify(customQuizzes));
  renderSavedQuizzes();
  showToast('🗑️ Quiz deleted','info');
}

/* ══════════════════════════════════════════
   ROLE SWITCH
══════════════════════════════════════════ */
function toggleRole(checkbox) {
  currentRole = checkbox.checked ? 'teacher' : 'student';
  applyRoleUI();
}

function applyRoleUI() {
  const isTeacher = currentRole === 'teacher';
  const label = document.getElementById('role-label');
  label.textContent = isTeacher ? '🍎 Teacher' : '🎒 Student';
  label.className = isTeacher ? 'teacher' : 'student';
  document.querySelectorAll('.teacher-only').forEach(el => el.classList.toggle('d-none',!isTeacher));
  document.querySelectorAll('.student-only').forEach(el => el.classList.toggle('d-none',isTeacher));
  const ab = document.getElementById('assign-role-badge');
  if (ab) { ab.textContent=isTeacher?'🍎 Teacher View':'🎒 Student View'; ab.style.background=isTeacher?'var(--teal)':'var(--sky)'; }
  const gb = document.getElementById('grades-role-badge');
  if (gb) { gb.textContent=isTeacher?'🍎 All Students':'🎒 Your Grades'; gb.style.background=isTeacher?'var(--teal)':'var(--sky)'; }
  if (isTeacher) renderSavedQuizzes();
  showToast(isTeacher?'🍎 Teacher mode — upload & quiz controls visible':'🎒 Student mode — personal access only', isTeacher?'success':'info');
}

/* ══════════════════════════════════════════
   UPLOAD LECTURE (teacher)
══════════════════════════════════════════ */
function uploadLecture(grade) {
  const titleEl = document.getElementById('ul'+grade+'-title');
  const fileEl  = document.getElementById('ul'+grade+'-file');
  if (!titleEl.value.trim()) { showToast('⚠️ Enter a lecture title.','warning'); return; }
  if (!fileEl.files[0])       { showToast('⚠️ Choose a PDF file.','warning'); return; }
  const title = titleEl.value.trim();
  const fname = fileEl.files[0].name;
  const list  = document.getElementById('g'+grade+'-pdf-list');
  const item  = document.createElement('div');
  item.className='pdf-item';
  item.innerHTML=`<div class="pdf-icon"><i class="bi bi-file-earmark-pdf-fill"></i></div><div class="pdf-meta"><strong>${title}</strong><span>PDF · Just uploaded</span></div><div class="d-flex gap-2 flex-wrap"><button class="btn-download" onclick="simDownload('${fname}')"><i class="bi bi-download me-1"></i>Download</button><button class="btn-danger-soft teacher-only" onclick="this.closest('.pdf-item').remove();showToast('Deleted','info')"><i class="bi bi-trash3"></i></button></div>`;
  list.appendChild(item);
  titleEl.value=''; fileEl.value='';
  showToast(`✅ "${title}" uploaded to Grade ${grade}!`,'success');
}

/* ══════════════════════════════════════════
   ASSIGNMENT HANDLERS
══════════════════════════════════════════ */
function handleUpload(event, type) {
  event.preventDefault();
  const fileInput = document.getElementById('pdfUpload');
  if (!fileInput || !fileInput.files[0]) { showToast('⚠️ Choose a PDF first.','warning'); return; }
  const file = fileInput.files[0];
  simulateUploadProgress(() => {
    addAssignmentToUI(document.getElementById('asgn-title').value, document.getElementById('asgn-grade').value, document.getElementById('asgn-due').value, file.name);
    document.getElementById('assignment-upload-form').reset();
    clearFile();
  });
}

function simulateUploadProgress(onComplete) {
  const wrap=document.getElementById('upload-progress'),bar=document.getElementById('progress-bar'),pct=document.getElementById('progress-pct'),btn=document.getElementById('upload-btn');
  if (!wrap){onComplete();return;}
  wrap.style.display='block';
  if(btn){btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split me-2"></i>Uploading…';}
  let progress=0;
  const iv=setInterval(()=>{
    progress+=Math.random()*18+5;
    if(progress>=100){progress=100;clearInterval(iv);}
    bar.style.width=progress+'%';pct.textContent=Math.round(progress)+'%';
    if(progress===100){setTimeout(()=>{wrap.style.display='none';bar.style.width='0%';pct.textContent='0%';if(btn){btn.disabled=false;btn.innerHTML='<i class="bi bi-upload me-2"></i>Post Assignment';}onComplete();},400);}
  },120);
}

function addAssignmentToUI(title,grade,dueDate,fileName) {
  const colors={'Grade 1':'var(--g1)','Grade 2':'var(--g2)','Grade 3':'var(--g3)','Grade 4':'var(--g4)','Grade 5':'var(--g5)'};
  const color=colors[grade]||'var(--teal)';
  const due=dueDate?new Date(dueDate).toLocaleDateString('en-GB',{day:'numeric',month:'short'}):'';
  const card=document.createElement('div');
  card.className='assignment-card';card.style.borderLeftColor=color;
  card.innerHTML=`<div class="card-header-custom"><div><strong>${grade} · ${title}</strong><div class="text-muted" style="font-size:.8rem">Posted by you · Just now</div></div>${due?`<span class="badge-due" style="background:#F5F3FF;color:#6D28D9">Due ${due}</span>`:''}</div><div class="p-3 d-flex align-items-center justify-content-between flex-wrap gap-2"><p class="text-muted small mb-0"><i class="bi bi-file-earmark-pdf text-danger me-1"></i>${fileName}</p><div class="d-flex gap-2"><button class="btn-download" onclick="simDownload('${fileName}')"><i class="bi bi-download me-1"></i>Get PDF</button><button class="btn-primary-custom teacher-only" style="font-size:.82rem;padding:.4rem 1rem"><i class="bi bi-eye me-1"></i>0 Submissions</button></div></div>`;
  document.querySelector('#page-assignments .col-lg-7').appendChild(card);
  card.scrollIntoView({behavior:'smooth',block:'center'});
  showToast(`✅ "${title}" posted to ${grade}!`,'success');
}

function handleStudentSubmit(event, title) {
  const file=event.target.files[0];
  if(!file)return;
  if(!file.name.endsWith('.pdf')){showToast('⚠️ PDF files only.','warning');return;}
  showToast(`📤 "${file.name}" submitted for "${title}"!`,'success');
  event.target.value='';
}

function onDragOver(e){e.preventDefault();document.getElementById('dropZone').classList.add('drag-over');}
function onDragLeave(){document.getElementById('dropZone').classList.remove('drag-over');}
function onDrop(e){
  e.preventDefault();document.getElementById('dropZone').classList.remove('drag-over');
  const file=e.dataTransfer.files[0];
  if(file&&file.type==='application/pdf'){const dt=new DataTransfer();dt.items.add(file);document.getElementById('pdfUpload').files=dt.files;showFileInfo(file);}
  else showToast('⚠️ PDF files only.','warning');
}
function onFileSelected(e){const file=e.target.files[0];if(file)showFileInfo(file);}
function showFileInfo(file){document.getElementById('file-name').textContent=file.name;document.getElementById('file-size').textContent=(file.size/1024).toFixed(1)+' KB';document.getElementById('file-info').classList.remove('d-none');}
function clearFile(){document.getElementById('pdfUpload').value='';document.getElementById('file-info').classList.add('d-none');}

/* ══════════════════════════════════════════
   GRADES TABLE FILTERS
══════════════════════════════════════════ */
function filterGrades(q){document.querySelectorAll('#grades-tbody tr').forEach(r=>{r.style.display=(r.dataset.student||'').toLowerCase().includes(q.toLowerCase())?'':' none';});}
function filterGradeByGrade(g){document.querySelectorAll('#grades-tbody tr').forEach(r=>{r.style.display=(!g||r.dataset.gl===g)?'':'none';});}

/* ══════════════════════════════════════════
   DOWNLOAD SIM
══════════════════════════════════════════ */
function simDownload(filename){showToast(`⬇️ Downloading "${filename}"…`,'info');}

/* ══════════════════════════════════════════
   TOAST
══════════════════════════════════════════ */
function showToast(msg,type='success'){
  const t=document.getElementById('liveToast'),m=document.getElementById('toast-msg');
  t.className='toast align-items-center border-0';
  if(type==='success')t.classList.add('text-bg-success');
  else if(type==='warning')t.classList.add('text-bg-warning','text-dark');
  else if(type==='info')t.classList.add('text-bg-info','text-dark');
  else t.classList.add('text-bg-danger');
  m.textContent=msg;
  new bootstrap.Toast(t,{delay:4000}).show();
}

