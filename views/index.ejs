<script>
  // 1. Toggle the window
function toggleChatbot() {
    const win = document.getElementById('chat-window');
    win.classList.toggle('d-none');
}

// 2. The Main AI Logic
function handleAI() {
    const input = document.getElementById('ai-input');
    const display = document.getElementById('chat-messages');
    const typing = document.getElementById('typing-indicator');
    const val = input.value.trim();

    if (!val) return;

    // Show User Message
    display.innerHTML += `<div class="text-end mb-3"><span class="p-2 rounded-3 bg-primary text-white d-inline-block">${val}</span></div>`;
    input.value = "";
    display.scrollTop = display.scrollHeight;

    // Show Typing
    typing.classList.remove('d-none');

    setTimeout(() => {
        typing.classList.add('d-none');
        let response = "I'm still learning! Try asking a math problem like '5 * 5'.";

        // Logic A: Solve Math
        const mathMatch = val.match(/(\d+)\s*([\+\-\*\/])\s*(\d+)/);
        if (mathMatch) {
            try {
                const result = eval(mathMatch[0]); 
                response = `Beep boop! **${mathMatch[0]} = ${result}**. Math is fun!`;
            } catch(e) { response = "That math is a bit tricky for me!"; }
        } 
        // Logic B: Website Navigation[cite: 1]
        else if (val.toLowerCase().includes("quiz")) {
            response = "You can find the **Quiz** in the top menu or the Quiz tab!";
        } else if (val.toLowerCase().includes("hello")) {
            response = "Hello! Ready to solve some math today?";
        }

        display.innerHTML += `<div class="mb-3"><span class="p-2 rounded-3 bg-light d-inline-block shadow-sm">${response}</span></div>`;
        display.scrollTop = display.scrollHeight;
    }, 800);
}

// 3. Enable "Enter" key support
document.addEventListener('DOMContentLoaded', () => {
    const aiInput = document.getElementById('ai-input');
    if(aiInput) {
        aiInput.addEventListener("keypress", (e) => {
            if (e.key === "Enter") handleAI();
        });
    }
});
</script>
