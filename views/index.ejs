<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MathWorld Primary | Grades 1–5</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
 <!-- Website Icon / Favicon -->
 
  <link rel="icon" type="image/png" href="https://img.icons8.com/color/48/math.png">
  <link rel="shortcut icon" type="image/png" href="https://img.icons8.com/color/48/math.png">
  <style>

     /* Scroll Up/Down Buttons */
.scroll-btn {
  position: fixed;
  bottom: 20px;
  right: 20px;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--violet), #A78BFA);
  color: white;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  z-index: 999;
}

#scrollDownBtn {
  bottom: 80px;  /* Down button upar rahega */
}

.scroll-btn:hover {
  transform: scale(1.1);
  background: linear-gradient(135deg, var(--yellow), #FFB347);
  color: var(--navy);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
}

.scroll-btn:active {
  transform: scale(0.95);
}

/* Hide buttons initially, show when needed */
.scroll-btn {
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.scroll-btn.show {
  opacity: 1;
  visibility: visible;
}
    :root {
      --yellow:#FFD600; --coral:#FF6B6B; --teal:#00C9B1; --violet:#7C5CFC;
      --sky:#38BDF8; --green:#22C55E; --orange:#FB923C; --navy:#1E2A4A;
      --cream:#FFFBF0; --card-r:16px;
      --g1:#FF6B6B; --g2:#FB923C; --g3:#D4AC00; --g4:#22C55E; --g5:#7C5CFC;
    }
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family:'Nunito',sans-serif; background:var(--cream); color:var(--navy); min-height:100vh; }
    h1,h2,h3,h4,.brand { font-family:'Fredoka One',cursive; }
    body::before {
      content:''; position:fixed; inset:0;
      background-image:radial-gradient(circle,#e2d9c8 1px,transparent 1px);
      background-size:28px 28px; opacity:.5; pointer-events:none; z-index:0;
    }

    /* ── NAV ── */
    #main-nav {
      background:var(--navy); padding:.6rem 1.5rem;
      position:sticky; top:0; z-index:1000;
      box-shadow:0 4px 20px rgba(0,0,0,.2);
    }
    .brand { font-size:1.7rem; color:var(--yellow); letter-spacing:.5px; text-decoration:none; display:flex; align-items:center; gap:.4rem; }
    .brand .star { font-size:1.3rem; animation:spin 6s linear infinite; display:inline-block; }
    @keyframes spin { to { transform:rotate(360deg); } }
    .nav-link-btn {
      background:transparent; border:2.5px solid transparent; color:#CBD5E1;
      font-family:'Nunito',sans-serif; font-weight:700; font-size:.95rem;
      padding:.45rem 1rem; border-radius:50px; cursor:pointer; transition:all .2s;
      text-decoration:none; display:inline-flex; align-items:center; gap:.35rem;
    }
    .nav-link-btn:hover,.nav-link-btn.active { border-color:var(--yellow); color:var(--yellow); background:rgba(255,214,0,.08); }
    #role-toggle-wrap { display:flex; align-items:center; gap:.6rem; background:rgba(255,255,255,.07); border-radius:50px; padding:.3rem .8rem; }
    #role-toggle-wrap span { font-size:.8rem; font-weight:700; color:#94A3B8; }
    .form-check-input:checked { background-color:var(--teal); border-color:var(--teal); }
    #role-label { font-weight:800; font-size:.85rem; padding:.2rem .75rem; border-radius:50px; transition:all .3s; }
    #role-label.student { background:var(--sky); color:var(--navy); }
    #role-label.teacher { background:var(--teal); color:var(--navy); }

    /* ── PAGES ── */
    .page { display:none; }
    .page.active { display:block; }
    .page-content { position:relative; z-index:1; }

    /* ── HERO ── */
<!-- Search Section -->
<div class="container mt-n4">
    <div class="bg-white p-4 rounded-4 shadow-sm mx-auto" style="max-width: 800px; position: relative; margin-top: -40px; z-index: 10;">
        <div class="row g-2">
            <div class="col-md-7">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control border-start-0" placeholder="Search for 'Fractions', 'Shapes'...">
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select"> <!-- Search Categories -->
                    <option selected>All Topics</option>
                    <option>Numbers</option>
                    <option>Geometry</option>
                    <option>Algebra</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary-custom w-100">Find</button>
            </div>
        </div>
    </div>
</div>
    #page-home { position:relative; z-index:1; min-height:calc(100vh - 66px); }
    .hero {
      background:linear-gradient(135deg,var(--violet) 0%,var(--navy) 60%,#0F172A 100%);
      padding:5rem 1.5rem 4rem; text-align:center; position:relative; overflow:hidden;
    }
    .hero::after {
      content:''; position:absolute; bottom:-2px; left:0; right:0; height:60px;
      background:var(--cream); clip-path:ellipse(55% 100% at 50% 100%);
    }
    .hero-badge {
      display:inline-flex; align-items:center; gap:.5rem;
      background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.2);
      color:#E2E8F0; font-size:.85rem; font-weight:700; border-radius:50px;
      padding:.35rem 1rem; margin-bottom:1.2rem; backdrop-filter:blur(6px);
    }
    .hero h1 { font-size:clamp(2.4rem,6vw,4.2rem); color:#fff; line-height:1.1; margin-bottom:1rem; }
    .hero h1 span { color:var(--yellow); }
    .hero p { color:#CBD5E1; font-size:1.1rem; max-width:560px; margin:0 auto 2rem; }
    .hero-btn {
      background:var(--yellow); color:var(--navy); font-weight:800; font-size:1rem;
      padding:.75rem 2rem; border-radius:50px; border:none; cursor:pointer;
      font-family:'Nunito',sans-serif; transition:transform .2s,box-shadow .2s;
      box-shadow:0 4px 20px rgba(255,214,0,.4);
    }
    .hero-btn:hover { transform:translateY(-3px); box-shadow:0 8px 28px rgba(255,214,0,.5); }

    /* ── GRADE CARDS (home) ── */
    .grade-card {
      border-radius:var(--card-r); border:none; overflow:hidden;
      box-shadow:0 4px 24px rgba(0,0,0,.08); transition:transform .22s,box-shadow .22s; cursor:pointer;
    }
    .grade-card:hover { transform:translateY(-6px); box-shadow:0 12px 36px rgba(0,0,0,.14); }
    .grade-card .card-top { height:8px; }
    .grade-card .icon-wrap {
      width:64px; height:64px; border-radius:50%; display:flex; align-items:center;
      justify-content:center; font-size:2rem; margin:1.4rem auto .8rem;
    }

    /* ── SECTION TITLES ── */
    .section-title {
      font-size:2rem; font-family:'Fredoka One',cursive; color:var(--navy);
      position:relative; display:inline-block; margin-bottom:.2rem;
    }
    .section-subtitle { color:#64748B; font-size:1rem; }
    .sticky-section-bar {
      background:rgba(255,251,240,.92); backdrop-filter:blur(8px);
      padding:1.4rem 0 .6rem; position:sticky; top:66px; z-index:100;
      border-bottom:1px solid #E2E8F0;
    }

    /* ── GRADE HUB PAGE ── */
    .grade-hub-header {
      padding:2.5rem 0 1.5rem;
      text-align:center;
    }
    .grade-selector-tabs {
      display:flex; gap:.75rem; flex-wrap:wrap; justify-content:center; margin-bottom:2rem;
    }
    .grade-tab {
      display:flex; flex-direction:column; align-items:center; gap:.3rem;
      padding:.9rem 1.4rem; border-radius:16px; cursor:pointer;
      border:3px solid transparent; background:#fff; font-weight:700;
      font-family:'Fredoka One',cursive; font-size:1.05rem; transition:all .25s;
      box-shadow:0 3px 12px rgba(0,0,0,.07); min-width:100px;
    }
    .grade-tab:hover { transform:translateY(-4px); box-shadow:0 8px 24px rgba(0,0,0,.12); }
    .grade-tab.active { color:#fff !important; transform:translateY(-4px); box-shadow:0 8px 24px rgba(0,0,0,.18); }
    .grade-tab .tab-emoji { font-size:1.6rem; }
    .grade-tab .tab-topics { font-family:'Nunito',sans-serif; font-size:.7rem; font-weight:600; opacity:.75; }

    /* ── GRADE CONTENT PANEL ── */
    .grade-panel { display:none; }
    .grade-panel.active { display:block; animation:fadeUp .35s ease both; }

    .panel-top-bar {
      border-radius:20px; padding:1.5rem 2rem; margin-bottom:1.5rem; color:#fff;
      display:flex; align-items:center; gap:1rem; flex-wrap:wrap;
    }
    .panel-top-bar h2 { font-family:'Fredoka One',cursive; font-size:2rem; margin:0; }
    .panel-top-bar p { margin:0; opacity:.9; font-size:.95rem; }

    /* Sub-tabs inside grade panel */
    .sub-tabs {
      display:flex; gap:.5rem; margin-bottom:1.5rem; flex-wrap:wrap;
      border-bottom:2px solid #E2E8F0; padding-bottom:.5rem;
    }
    .sub-tab {
      padding:.5rem 1.2rem; border-radius:50px; cursor:pointer; border:none;
      font-family:'Nunito',sans-serif; font-weight:700; font-size:.9rem;
      background:#F1F5F9; color:#64748B; transition:all .2s;
    }
    .sub-tab:hover { background:#E2E8F0; }
    .sub-tab.active { color:#fff; }

    /* ── LECTURE / PDF ITEMS ── */
    .pdf-item {
      display:flex; align-items:center; justify-content:space-between;
      background:#fff; border-radius:12px; padding:.85rem 1.1rem;
      margin-bottom:.6rem; box-shadow:0 2px 8px rgba(0,0,0,.06); transition:all .2s;
    }
    .pdf-item:hover { box-shadow:0 4px 16px rgba(0,0,0,.1); transform:translateX(3px); }
    .pdf-icon { width:40px;height:40px;background:#FEE2E2;border-radius:10px;display:flex;align-items:center;justify-content:center;color:#EF4444;font-size:1.1rem;margin-right:.8rem;flex-shrink:0; }
    .pdf-meta { flex:1; }
    .pdf-meta strong { display:block;font-size:.95rem;color:var(--navy); }
    .pdf-meta span { font-size:.78rem;color:#94A3B8; }

    /* ── YOUTUBE CARDS ── */
    .yt-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:1rem; }
    .yt-card {
      background:#fff; border-radius:14px; overflow:hidden;
      box-shadow:0 3px 14px rgba(0,0,0,.07); transition:all .22s; cursor:pointer;
    }
    .yt-card:hover { transform:translateY(-4px); box-shadow:0 10px 28px rgba(0,0,0,.12); }
    .yt-thumb {
      position:relative; background:#1E2A4A; aspect-ratio:16/9;
      display:flex; align-items:center; justify-content:center; overflow:hidden;
    }
    .yt-thumb img { width:100%; height:100%; object-fit:cover; }
    .yt-thumb .play-btn {
      position:absolute; width:52px; height:52px; background:rgba(255,0,0,.9);
      border-radius:50%; display:flex; align-items:center; justify-content:center;
      color:#fff; font-size:1.4rem; transition:transform .2s;
    }
    .yt-card:hover .play-btn { transform:scale(1.15); }
    .yt-info { padding:.9rem 1rem; }
    .yt-info strong { display:block; font-size:.9rem; color:var(--navy); margin-bottom:.2rem; }
    .yt-info span { font-size:.75rem; color:#94A3B8; }
    .yt-duration {
      position:absolute; bottom:.4rem; right:.4rem; background:rgba(0,0,0,.75);
      color:#fff; font-size:.7rem; font-weight:700; padding:.15rem .4rem; border-radius:4px;
    }

    /* YouTube Modal */
    .yt-modal-overlay {
      display:none; position:fixed; inset:0; background:rgba(0,0,0,.85);
      z-index:9998; align-items:center; justify-content:center;
    }
    .yt-modal-overlay.open { display:flex; }
    .yt-modal {
      background:#000; border-radius:16px; overflow:hidden; width:90%; max-width:840px;
      position:relative; box-shadow:0 20px 60px rgba(0,0,0,.5);
    }
    .yt-modal iframe { width:100%; aspect-ratio:16/9; border:none; display:block; }
    .yt-modal-close {
      position:absolute; top:.6rem; right:.6rem; z-index:2;
      background:rgba(255,255,255,.15); border:none; color:#fff; border-radius:50%;
      width:36px; height:36px; font-size:1.2rem; cursor:pointer; display:flex;
      align-items:center; justify-content:center; transition:background .2s;
    }
    .yt-modal-close:hover { background:rgba(255,255,255,.3); }

    /* ── TIMETABLE ── */
    .timetable-wrap { overflow-x:auto; }
    .timetable {
      width:100%; border-collapse:separate; border-spacing:4px;
      min-width:640px;
    }
    .timetable th {
      background:var(--navy); color:#fff; font-family:'Fredoka One',cursive;
      font-size:.95rem; font-weight:400; padding:.7rem .9rem; border-radius:8px; text-align:center;
    }
    .timetable td {
      background:#fff; border-radius:10px; padding:.75rem .9rem; text-align:center;
      font-size:.85rem; font-weight:600; vertical-align:middle;
      box-shadow:0 2px 6px rgba(0,0,0,.05); min-width:110px; transition:all .2s;
    }
    .timetable td:hover { transform:scale(1.04); box-shadow:0 4px 12px rgba(0,0,0,.1); }
    .timetable td.slot-active { color:#fff; }
    .timetable td.slot-break { background:#F8FAFC; color:#94A3B8; font-style:italic; }
    .timetable .row-label { background:#F1F5F9; color:var(--navy); font-weight:800; font-size:.82rem; text-align:right; padding-right:1rem; }
    .timetable-legend { display:flex; gap:.75rem; flex-wrap:wrap; margin-top:.75rem; }
    .legend-dot { display:inline-flex; align-items:center; gap:.35rem; font-size:.8rem; font-weight:700; }
    .legend-dot span { width:14px; height:14px; border-radius:4px; display:inline-block; }

    /* ── QUIZ (Teacher) ── */
    .quiz-builder-card {
      background:#fff; border-radius:var(--card-r);
      box-shadow:0 4px 20px rgba(0,0,0,.07); padding:1.5rem;
    }
    .quiz-question-item {
      background:#F8FAFC; border-radius:12px; padding:1rem 1.2rem;
      margin-bottom:.75rem; border-left:4px solid var(--violet);
    }
    .quiz-option-row { display:flex; gap:.5rem; align-items:center; margin-bottom:.4rem; }
    .quiz-option-row input[type=radio] { width:16px; height:16px; accent-color:var(--violet); cursor:pointer; }
    .quiz-correct-label { color:var(--green); font-weight:700; font-size:.78rem; margin-left:.3rem; }

    /* student quiz-play */
    .quiz-play-card {
      background:#fff; border-radius:var(--card-r); box-shadow:0 4px 20px rgba(0,0,0,.07);
      padding:2rem; max-width:640px; margin:0 auto;
    }
    .quiz-q-display { font-size:1.1rem; font-weight:700; margin-bottom:1rem; color:var(--navy); }
    .quiz-option-btn {
      display:block; width:100%; text-align:left; padding:.75rem 1.1rem;
      border-radius:10px; border:2px solid #E2E8F0; background:#fff;
      font-family:'Nunito',sans-serif; font-weight:700; font-size:.95rem;
      cursor:pointer; margin-bottom:.5rem; transition:all .2s; color:var(--navy);
    }
    .quiz-option-btn:hover { border-color:var(--violet); background:#F5F3FF; }
    .quiz-option-btn.correct { background:#DCFCE7; border-color:var(--green); color:#15803D; }
    .quiz-option-btn.wrong { background:#FEE2E2; border-color:var(--coral); color:#991B1B; }
    .quiz-progress-bar { height:8px; background:#E2E8F0; border-radius:4px; overflow:hidden; margin-bottom:1.2rem; }
    .quiz-progress-fill { height:100%; border-radius:4px; transition:width .4s ease; }
    .quiz-score-badge {
      display:inline-block; padding:.5rem 1.5rem; border-radius:50px;
      font-family:'Fredoka One',cursive; font-size:1.6rem; margin-bottom:.5rem;
    }

    /* ── NOTEPAD ── */
    .notepad-wrap {
      background:#fff; border-radius:var(--card-r);
      box-shadow:0 4px 20px rgba(0,0,0,.07); overflow:hidden;
    }
    .notepad-header {
      display:flex; align-items:center; justify-content:space-between;
      padding:1rem 1.4rem; border-bottom:2px solid #F1F5F9;
    }
    .notepad-textarea {
      width:100%; min-height:260px; border:none; outline:none; resize:vertical;
      font-family:'Nunito',sans-serif; font-size:.95rem; color:var(--navy);
      padding:1.2rem 1.4rem; line-height:1.9;
      background-image:repeating-linear-gradient(transparent, transparent 30px, #E8F0FE 30px, #E8F0FE 31px);
      background-size:100% 31px;
    }
    .notepad-toolbar { display:flex; gap:.5rem; padding:.75rem 1.4rem; background:#F8FAFC; flex-wrap:wrap; align-items:center; border-top:1px solid #F1F5F9; }
    .note-btn {
      padding:.35rem .8rem; border-radius:8px; border:1.5px solid #E2E8F0;
      background:#fff; font-family:'Nunito',sans-serif; font-weight:700; font-size:.8rem;
      cursor:pointer; transition:all .18s; color:var(--navy);
    }
    .note-btn:hover { background:var(--navy); color:#fff; border-color:var(--navy); }
    .note-btn.danger:hover { background:#EF4444; border-color:#EF4444; color:#fff; }
    .note-saved { font-size:.78rem; color:var(--green); font-weight:700; display:none; }
    .note-saved.show { display:inline; }

    /* ── ASSIGNMENTS ── */
    .assignment-card {
      background:#fff; border-radius:var(--card-r); box-shadow:0 4px 20px rgba(0,0,0,.06);
      overflow:hidden; margin-bottom:1.2rem; border-left:6px solid var(--teal); transition:transform .2s;
    }
    .assignment-card:hover { transform:translateX(4px); }
    .assignment-card .card-header-custom {
      background:#F8FAFC; padding:.8rem 1.2rem; border-bottom:1px solid #F1F5F9;
      display:flex; justify-content:space-between; align-items:center;
    }
    .badge-due { font-size:.72rem; font-weight:700; padding:.3rem .75rem; border-radius:50px; }
    .upload-form-card { background:#fff; border-radius:var(--card-r); box-shadow:0 4px 24px rgba(0,0,0,.07); padding:2rem; border-top:6px solid var(--teal); }
    .file-drop-zone { border:2.5px dashed #CBD5E1; border-radius:12px; padding:2.5rem 1.5rem; text-align:center; background:#F8FAFC; cursor:pointer; transition:all .2s; }
    .file-drop-zone:hover,.file-drop-zone.drag-over { border-color:var(--teal); background:#F0FEFB; }
    .progress-wrap { display:none; }
    .teacher-upload-card { background:linear-gradient(135deg,#EEF2FF,#F5F3FF); border:2px dashed var(--violet); border-radius:var(--card-r); padding:1.5rem; text-align:center; }

    /* ── GRADES PAGE ── */
    .grades-table-card { background:#fff; border-radius:var(--card-r); box-shadow:0 4px 24px rgba(0,0,0,.07); overflow:hidden; }
    .grades-table thead th { background:var(--navy); color:#fff; font-family:'Fredoka One',cursive; font-size:1rem; font-weight:400; padding:1rem 1.2rem; border:none; }
    .grades-table tbody tr { transition:background .15s; }
    .grades-table tbody tr:hover { background:#F8FAFC; }
    .grades-table tbody td { padding:.9rem 1.2rem; vertical-align:middle; border-color:#F1F5F9; }
    .grade-pill { display:inline-block; font-weight:800; font-size:.85rem; padding:.25rem .75rem; border-radius:50px; min-width:48px; text-align:center; }
    .grade-a{background:#DCFCE7;color:#15803D} .grade-b{background:#DBEAFE;color:#1D4ED8}
    .grade-c{background:#FEF9C3;color:#854D0E} .grade-d{background:#FFE4E6;color:#BE123C}
    .permission-table th{background:var(--violet);color:#fff;font-family:'Fredoka One',cursive;font-weight:400}
    .permission-table td{vertical-align:middle}
    .perm-yes{color:var(--green);font-weight:800} .perm-no{color:#94A3B8}

    /* ── BUTTONS ── */
    .btn-primary-custom { background:var(--violet);color:#fff;border:none;font-weight:700;border-radius:50px;padding:.55rem 1.4rem;font-family:'Nunito',sans-serif;transition:all .2s; }
    .btn-primary-custom:hover { background:#6A4AE8;transform:translateY(-2px); }
    .btn-teal { background:var(--teal);color:var(--navy);border:none;font-weight:700;border-radius:50px;padding:.55rem 1.4rem;font-family:'Nunito',sans-serif;transition:all .2s; }
    .btn-teal:hover { background:#00B09E;transform:translateY(-2px); }
    .btn-download { background:var(--navy);color:#fff;border:none;font-weight:700;font-size:.82rem;border-radius:50px;padding:.4rem 1rem;font-family:'Nunito',sans-serif;transition:all .2s;white-space:nowrap; }
    .btn-download:hover { background:var(--violet);transform:translateY(-1px); }
    .btn-danger-soft { background:#FEE2E2;color:#EF4444;border:none;font-weight:700;font-size:.82rem;border-radius:50px;padding:.4rem 1rem;font-family:'Nunito',sans-serif;transition:all .2s; }
    .btn-danger-soft:hover { background:#FECACA; }

    /* ── TOAST ── */
    .toast-container { z-index:9999; }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar{width:8px} ::-webkit-scrollbar-track{background:#F1F5F9} ::-webkit-scrollbar-thumb{background:#CBD5E1;border-radius:4px}

    /* ── ANIMATIONS ── */
    @keyframes fadeUp { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:translateY(0)} }
