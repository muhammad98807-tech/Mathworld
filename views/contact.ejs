<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Contact Us | MathWorld</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #FFFBF0; }
    .map-container { height: 400px; width: 100%; border-radius: 15px; overflow: hidden; margin-top: 20px; }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container py-5">
    <div class="row">
      <div class="col-md-6">
        <h2>Send us a Message</h2>
        <form action="/contact" method="POST" id="contactForm">
          <div class="mb-3">
            <label class="form-label">Name</label>
            <input type="text" name="name" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Message</label>
            <textarea name="message" class="form-control" rows="5" id="messageBox" required></textarea>
            <div id="wordCount" class="text-muted mt-1">0 / 250 words</div>
          </div>
          <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
      </div>
      <div class="col-md-6">
        <h2>Find Us</h2>
        <div class="map-container shadow">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3619.31399252169!2d67.0728!3d24.8827!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjTCsDUyJzU3LjciTiA2N8KwMDQnMjIuMSJF!5e0!3m2!1sen!2s!4v1650000000000" 
            width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy">
          </iframe>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script>
    const messageBox = document.getElementById('messageBox');
    const wordCount = document.getElementById('wordCount');
    
    messageBox.addEventListener('input', () => {
      const words = messageBox.value.trim().split(/\s+/).filter(w => w.length > 0);
      wordCount.innerText = words.length + ' / 250 words';
      if (words.length > 250) {
        wordCount.classList.add('text-danger');
        messageBox.setCustomValidity('Too many words!');
      } else {
        wordCount.classList.remove('text-danger');
        messageBox.setCustomValidity('');
      }
    });
  </script>
</body>
</html>
