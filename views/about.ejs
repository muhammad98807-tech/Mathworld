  <style>
    :root {
      --yellow: #FFD600;
      --coral: #FF6B6B;
      --teal: #00C9B1;
      --violet: #7C5CFC;
      --sky: #38BDF8;
      --green: #22C55E;
      --orange: #FB923C;
      --navy: #1E2A4A;
      --cream: #FFFBF0;
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Nunito', sans-serif;
      background: var(--cream);
      color: var(--navy);
      min-height: 100vh;
    }
    
    h1, h2, h3, h4, .brand {
      font-family: 'Fredoka One', cursive;
    }
    
    /* Background pattern */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: radial-gradient(circle, #e2d9c8 1px, transparent 1px);
      background-size: 28px 28px;
      opacity: 0.5;
      pointer-events: none;
      z-index: 0;
    }
    
    /* Navigation Bar */
    #main-nav {
      background: var(--navy);
      padding: 0.7rem 1.5rem;
      position: sticky;
      top: 0;
      z-index: 1000;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    }
    
    .brand {
      font-size: 1.7rem;
      color: var(--yellow);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    
    .brand .star {
      font-size: 1.3rem;
      animation: spin 6s linear infinite;
      display: inline-block;
    }
    
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    
    .nav-link-btn {
      background: transparent;
      border: 2px solid transparent;
      color: #CBD5E1;
      font-weight: 700;
      font-size: 0.95rem;
      padding: 0.45rem 1rem;
      border-radius: 50px;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
    }
    
    .nav-link-btn:hover {
      border-color: var(--yellow);
      color: var(--yellow);
      background: rgba(255, 214, 0, 0.08);
    }
    
    .nav-link-btn.active {
      border-color: var(--yellow);
      color: var(--yellow);
      background: rgba(255, 214, 0, 0.15);
    }
    
    /* Page Container */
    .page-content {
      position: relative;
      z-index: 1;
      padding: 2rem 0;
    }
    
    /* Hero Section */
    .about-hero {
      background: linear-gradient(135deg, var(--violet) 0%, var(--navy) 70%, #0F172A 100%);
      padding: 4rem 1.5rem;
      border-radius: 0 0 50px 50px;
      text-align: center;
      color: white;
      margin-bottom: 3rem;
    }
    
    .about-hero h1 {
      font-size: 3rem;
      margin-bottom: 1rem;
    }
    
    .about-hero h1 span {
      color: var(--yellow);
    }
    
    .about-hero p {
      font-size: 1.2rem;
      max-width: 700px;
      margin: 0 auto;
      color: #CBD5E1;
    }
    
    /* Section Styles */
    .section-card {
      background: #fff;
      border-radius: 24px;
      padding: 2rem;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      transition: transform 0.3s, box-shadow 0.3s;
      height: 100%;
    }
    
    .section-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
    }
    
    .section-icon {
      width: 70px;
      height: 70px;
      background: linear-gradient(135deg, var(--violet), #A78BFA);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.2rem;
    }
    
    .section-icon i {
      font-size: 2rem;
      color: white;
    }
    
    /* Team Member Card */
    .team-card {
      text-align: center;
      background: #fff;
      border-radius: 20px;
      padding: 1.5rem;
      transition: all 0.3s;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    }
    
    .team-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
    }
    
    .team-avatar {
      width: 120px;
      height: 120px;
      background: linear-gradient(135deg, var(--violet), var(--orange));
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1rem;
    }
    
    .team-avatar i {
      font-size: 3.5rem;
      color: white;
    }
    
    /* Stats Counter */
    .stat-box {
      text-align: center;
      padding: 1.5rem;
      background: linear-gradient(135deg, #1E2A4A, #2D3A5A);
      border-radius: 20px;
      color: white;
      transition: transform 0.3s;
    }
    
    .stat-box:hover {
      transform: scale(1.05);
    }
    
    .stat-number {
      font-size: 2.5rem;
      font-family: 'Fredoka One', cursive;
      color: var(--yellow);
    }
    
    /* Mission Vision */
    .mv-card {
      background: #fff;
      border-radius: 20px;
      padding: 1.8rem;
      text-align: center;
      height: 100%;
      transition: all 0.3s;
      border-bottom: 4px solid var(--violet);
    }
    
    .mv-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    }
    
    .mv-icon {
      font-size: 2.5rem;
      color: var(--violet);
      margin-bottom: 1rem;
    }
    
    /* Footer */
    .footer {
      background: var(--navy);
      color: #CBD5E1;
      text-align: center;
      padding: 1.5rem;
      margin-top: 3rem;
    }
    
    .footer a {
      color: var(--yellow);
      text-decoration: none;
    }
    
    /* Responsive */
    @media (max-width: 768px) {
      .about-hero h1 {
        font-size: 2rem;
      }
      .section-card {
        padding: 1.5rem;
      }
    }
  </style>
</head>
