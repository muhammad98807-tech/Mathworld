<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard | MathWorld</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <span class="navbar-brand">MathWorld Admin</span>
            <a href="/" class="btn btn-outline-light btn-sm">View Site</a>
        </div>
    </nav>
    <div class="container">
        <div class="row">
            <div class="col-md-3">
                <div class="list-group">
                    <a href="/admin/dashboard" class="list-group-item list-group-item-action active">Dashboard</a>
                    <a href="/admin/users" class="list-group-item list-group-item-action">Users</a>
                    <a href="/admin/inventory" class="list-group-item list-group-item-action">Inventory</a>
                </div>
            </div>
            <div class="col-md-9">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="card bg-primary text-white text-center p-4">
                            <h3><%= userCount %></h3>
                            <p>Registered Users</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-success text-white text-center p-4">
                            <h3><%= itemCount %></h3>
                            <p>Inventory Items</p>
                        </div>
                    </div>
                </div>
                <div class="card p-4">
                    <h5>Recent Feedback</h5>
                    <table class="table">
                        <thead><tr><th>Name</th><th>Message</th></tr></thead>
                        <tbody>
                            <% messages.forEach(msg => { %>
                                <tr><td><%= msg.name %></td><td><%= msg.message %></td></tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
